# TOBio 프론트 환경변수 (Vite). 실제 값은 .env 파일에 넣으세요(.env는 커밋 금지).
# ⚠️ 프론트엔드에 노출되는 값만 둡니다. service_role 같은 비밀키는 절대 금지.

# 백엔드(추천/살포) — 비우면 운영 Render 주소 사용
VITE_API_BASE_URL=https://microbe-recommend-website.onrender.com

# 카카오 주소검색 REST 키 (카카오 콘솔에서 도메인 제한 필수)
VITE_KAKAO_REST_KEY=

# Supabase (로그인/기록). 새 프로젝트 생성 후 값 채우기.
# - URL: 프로젝트 URL (https://xxxx.supabase.co)
# - PUBLISHABLE_KEY: publishable(anon) 키. sb_publishable_... 또는 옛 anon JWT.
#   ⚠️ service_role 키는 절대 여기 넣지 마세요.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
